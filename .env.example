# votx-agent 环境变量（仅做兜底，config.json 优先）
# 复制为 .env 并填入实际值

# ═══════════════════════════════════════════
# 安全（⚠️ 生产环境务必修改）
# ═══════════════════════════════════════════
# VOTX_SECRET_KEY=your-random-secret-here    # Flask session 签名密钥（留空则用 .session_secret 文件或项目路径 hash）
# VOTX_ACCESS_TOKEN=your-api-token-here      # Web API Bearer token 认证（留空则不鉴权，所有请求可直接调用）

# ═══════════════════════════════════════════
# Provider 强制覆盖（兜底优先级 < config.json）
# ═══════════════════════════════════════════
# 仅支持: kemo
# Provider 接入方式：
# - 推荐模式 → 搭配 Kemo LLM Adapter 网关（https://github.com/kesepain-KE/llm-adapter-kemo），多模态全开
# - 兼容模式 → 直连任意 OpenAI 兼容 API（base_url 指向谁就是谁），部分端点（如图生图、视频、部分 ASR 路由）可能不可用
# 配置上改 base_url 和 api_key 即可切换，provider type 统一填 "kemo"
# 留空则使用 config.json 中的 provider.type
# VOTX_PROVIDER=kemo

# ═══════════════════════════════════════════
# Kemo LLM Adapter / OpenAI-compatible endpoint（兜底）
# ═══════════════════════════════════════════
KEMO_API_KEY=sk-kemo-your-key-here
# KEMO_BASE_URL=http://127.0.0.1:8741/v1

# ═══════════════════════════════════════════
# 第三方工具
# ═══════════════════════════════════════════
# TAVILY_API_KEY=your-tavily-key     # 网络搜索（申请地址: https://app.tavily.com）

# ═══════════════════════════════════════════
# Web UI 访问控制
# ═══════════════════════════════════════════
# 默认只允许本机访问: http://localhost:1478
# 如需局域网访问，请取消下面两行注释并重启 Web:
# PORT=1478
# VOTX_HOST=0.0.0.0
# 同一 IP 跑多个 Web 服务时，避免 Flask 默认 session cookie 冲突。
# 多个 votx-agent 实例也可分别改成 votx_agent_1478 / votx_agent_1479 等。
# VOTX_SESSION_COOKIE_NAME=votx_agent_session
#
# 局域网访问地址:
# http://<运行 votx-agent 的机器局域网 IP>:1478
#
# 安全提示:
# - 仅在可信局域网内启用 0.0.0.0。
# - 不建议直接暴露到公网；公网访问请使用 VPN、反向代理、HTTPS 和访问控制。
#
# --- 版本检查 ---
# VOTX_SKIP_VERSION_CHECK=1                  # 设为 1 跳过启动时的版本检测
# VOTX_VERSION_URL=https://example.com/ver   # 自定义版本检测 URL（留空用默认 GitHub API）

# ═══════════════════════════════════════════
# 路径覆写
# ═══════════════════════════════════════════
# VOTX_USER_DIR=/path/to/users               # 用户数据目录（留空用默认 ./users）
# VOTX_MESSAGE_CONFIG=/path/to/config.json   # 消息路由配置文件路径（留空用默认 message/config.local.json）

# ═══════════════════════════════════════════
# 外部消息路由（QQ / Telegram）
# ═══════════════════════════════════════════
# QQ/Telegram 的 bot token、WebSocket 地址等 → 见 message/config.local.json
# 配置示例 → 见 message/config.example.json

# ═══════════════════════════════════════════
# 网络与调试
# ═══════════════════════════════════════════
# HTTP_PROXY=http://127.0.0.1:7890  # HTTP 代理
# HTTPS_PROXY=http://127.0.0.1:7890 # HTTPS 代理
# SSL_CERT_FILE=                    # 自定义 SSL 证书路径（Windows 下无效路径会自动清除，一般无需设置）

# ═══════════════════════════════════════════
# 结果截断（字符数，0 或不设 = 不截断）
# ═══════════════════════════════════════════
# DOCX_RESULT_TRUNCATE=8000         # Word 文档工具结果截断
# PDF_RESULT_TRUNCATE=8000          # PDF 工具结果截断
# TAVILY_RESULT_TRUNCATE=8000       # Tavily 搜索结果截断

# ═══════════════════════════════════════════
# 下载限制
# ═══════════════════════════════════════════
# DOWNLOAD_MAX_BYTES=1073741824      # 直链下载最大字节数（默认 1GB）
# DOWNLOAD_TIMEOUT=120               # 下载超时秒数（默认 60）
# DOWNLOAD_VIDEO_TIMEOUT=600         # 视频下载超时秒数（默认 300）

# ═══════════════════════════════════════════
# 沙箱限制放开（⚠️ 安全敏感，仅在信任环境启用）
# ═══════════════════════════════════════════

# --- 文件操作沙箱 ---
# 默认: 文件操作只允许项目根目录和当前用户目录
# 以下变量可逐级放开限制，设为 1/true/yes/on 生效

# VOTX_FILE_OUTSIDE_SANDBOX=1        # 全局放开所有文件操作沙箱（读写删均可越过）
# VOTX_FILE_READ_OUTSIDE_SANDBOX=1   # 仅放开读取类（read_file/list_dir/tree_dir/search_files/stat）
# VOTX_FILE_EDIT_OUTSIDE_SANDBOX=1   # 仅放开写入/编辑类（write_file/append_file/edit_file/copy/move/mkdir）
# VOTX_FILE_WRITE_OUTSIDE_SANDBOX=1  # 仅放开写入类（write_file/append_file）
# VOTX_FILE_DELETE_OUTSIDE_SANDBOX=1 # 仅放开删除类（delete_file）

# --- 下载工具沙箱 ---
# 默认: download_anything 工具只能写到 users/<name>/download/ 或 history/file/
# VOTX_DOWNLOAD_ANYTHING_OUTSIDE_SANDBOX=1  # 允许下载到任意本地目录

# --- 网络请求沙箱 ---
# 默认: 网络工具仅允许访问公网地址 (network_scope=public)
# 工具调用时可通过 network_scope 参数逐次指定: public / local / private / all
# 以下变量控制底层行为，一般不需要改:

# VOTX_NETWORK_SCOPE=public          # 默认网络范围: public / local / private / all
# HTTP_NETWORK_SCOPE=public          # 兼容变量名，优先级低于 VOTX_NETWORK_SCOPE
# NETWORK_SCOPE=public               # 兼容变量名，优先级最低
# HTTP_TIMEOUT=30                   # HTTP 请求超时秒数（默认 15）
# HTTP_VERIFY_SSL=0                 # 跳过 SSL 证书验证（默认验证）
