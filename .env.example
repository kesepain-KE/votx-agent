# votx-agent 环境变量模板
# 复制为 .env 并填入实际值

# API Key（必填）
DEEPSEEK_API_KEY=sk-your-key-here

# 可选：自定义 API 地址
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# vision密钥
# OPENAI_API_KEY=

# 热榜查询（可选）
# UAPI_API_KEY=your-uapi-key

# 网络搜索（可选）
# TAVILY_API_KEY=your-tavily-key

# HTTP 超时（可选，默认 15s）
# HTTP_TIMEOUT=15

# 代理（可选，HTTP/HTTPS 请求自动走此代理）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# SSL 证书验证（可选，设为 0 跳过验证，解决部分 Windows 环境证书链问题）
# HTTP_VERIFY_SSL=1
