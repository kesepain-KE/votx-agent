# votx-agent 环境变量（仅做兜底，config.json 优先）
# 复制为 .env 并填入实际值

# ═══════════════════════════════════════════
# Provider 强制覆盖（兜底优先级 < config.json）
# ═══════════════════════════════════════════
# 仅支持: kemo
# 留空则使用 config.json 中的 provider.type
# VOTX_PROVIDER=kemo

# ═══════════════════════════════════════════
# Kemo LLM Adapter 本地网关（兜底）
# ═══════════════════════════════════════════
KEMO_API_KEY=sk-kemo-your-key-here
# KEMO_BASE_URL=http://127.0.0.1:8741/v1

# ═══════════════════════════════════════════
# 第三方工具
# ═══════════════════════════════════════════
# TAVILY_API_KEY=your-tavily-key     # 网络搜索

# ═══════════════════════════════════════════
# Web UI 访问控制
# ═══════════════════════════════════════════
# 默认只允许本机访问: http://localhost:1478
# 如需局域网访问，请取消下面两行注释并重启 Web:
# PORT=1478
# VOTX_HOST=0.0.0.0
# 同一 IP 跑多个 Web 服务时，避免 Flask 默认 session cookie 冲突。
# 多个 votx-agent 实例也可分别改成 votx_agent_1478 / votx_agent_1479 等。
# VOTX_SESSION_COOKIE_NAME=votx_agent_session
#
# 局域网访问地址:
# http://<运行 votx-agent 的机器局域网 IP>:1478
#
# 安全提示:
# - 仅在可信局域网内启用 0.0.0.0。
# - 不建议直接暴露到公网；公网访问请使用 VPN、反向代理、HTTPS 和访问控制。

# ═══════════════════════════════════════════
# 网络与调试
# ═══════════════════════════════════════════
# HTTP_PROXY=http://127.0.0.1:7890  # HTTP 代理
# HTTPS_PROXY=http://127.0.0.1:7890 # HTTPS 代理

# ═══════════════════════════════════════════
# 沙箱限制放开（⚠️ 安全敏感，仅在信任环境启用）
# ═══════════════════════════════════════════

# --- 文件操作沙箱 ---
# 默认: 文件操作只允许项目根目录和当前用户目录
# 以下变量可逐级放开限制，设为 1/true/yes/on 生效

# VOTX_FILE_OUTSIDE_SANDBOX=1       # 全局放开所有文件操作沙箱（读写删均可越过）
# VOTX_FILE_READ_OUTSIDE_SANDBOX=1  # 仅放开读取类（read_file/list_dir/tree_dir/search_files/stat）
# VOTX_FILE_EDIT_OUTSIDE_SANDBOX=1  # 仅放开写入/编辑类（write_file/append_file/edit_file/copy/move/mkdir）
# VOTX_FILE_DELETE_OUTSIDE_SANDBOX=1# 仅放开删除类（delete_file）

# --- 下载工具沙箱 ---
# 默认: download_anything 工具只能写到 users/<name>/download/ 或 history/file/
# VOTX_DOWNLOAD_ANYTHING_OUTSIDE_SANDBOX=1  # 允许下载到任意本地目录

# --- 网络请求沙箱 ---
# 默认: 网络工具仅允许访问公网地址 (network_scope=public)
# 工具调用时可通过 network_scope 参数逐次指定: public / local / private / all
# 以下变量控制底层行为，一般不需要改:

# VOTX_NETWORK_SCOPE=public          # 默认网络范围: public / local / private / all
# HTTP_NETWORK_SCOPE=public          # 兼容变量名，优先级低于 VOTX_NETWORK_SCOPE
# NETWORK_SCOPE=public               # 兼容变量名，优先级最低
# HTTP_TIMEOUT=30                   # HTTP 请求超时秒数（默认 15）
# HTTP_VERIFY_SSL=0                 # 跳过 SSL 证书验证（默认验证）
