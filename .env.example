# votx-agent 可选环境变量
#
# 运行配置以以下两个 JSON 文件为主：
#   1. config/config_core.json          全局默认配置
#   2. users/<name>/config.json         用户配置（优先级更高）
#
# 本文件只保留源码仍直接读取、且不属于常规 JSON 配置的启动级或兼容变量。
# 复制为 .env 后按需取消注释。不要提交真实密钥。

# ── Provider 兼容兜底 ──────────────────────────────
# Provider 的 model、base_url、api_key 等应优先写入 users/<name>/config.json。
# 以下两项仅在用户配置未填写时作为兜底。
# KEMO_API_KEY=your-api-key
# KEMO_BASE_URL=http://127.0.0.1:8741/v1

# ── 第三方服务 ─────────────────────────────────────
# Tavily 搜索插件没有对应的用户 JSON 密钥字段，启用该插件时需要此变量。
# TAVILY_API_KEY=your-tavily-key
# TAVILY_RESULT_TRUNCATE=8000      # 0 或不设置表示不截断

# ── Web 启动与会话 ─────────────────────────────────
# PORT=1478
# VOTX_HOST=127.0.0.1
# VOTX_SESSION_COOKIE_NAME=votx_agent_session
# VOTX_SECRET_KEY=replace-with-a-random-secret
# VOTX_ACCESS_TOKEN=replace-with-an-api-token
#   设置后，访问 Web UI 需要在 URL 中带 ?token=xxx 完成鉴权：
#   http://host:port?token=replace-with-an-api-token
#   首次命中后写入 Flask session，后续请求靠 cookie 自动放行。
#   留空则不鉴权，任何人可直接访问。
#   API 调用也可通过 Authorization: Bearer xxx 头传递 token。

# ── 启动版本检查 ───────────────────────────────────
# VOTX_SKIP_VERSION_CHECK=1
# VOTX_VERSION_URL=https://example.com/version.json

# ── 外部消息路由 ───────────────────────────────────
# 留空时依次读取 message/config.local.json、message/config.json。
# VOTX_MESSAGE_CONFIG=/path/to/message-config.json

# ── HTTP 兼容设置 ──────────────────────────────────
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=127.0.0.1,localhost
# SSL_CERT_FILE=/path/to/ca-bundle.pem
# HTTP_VERIFY_SSL=0                # 仅调试证书问题时关闭验证

# 以下超时变量仍由兼容代码读取，但工具执行时间最终优先服从
# users/<name>/config.json 或 config/config_core.json 中的 tool.tool_timeout。
# HTTP_TIMEOUT=15
# DOWNLOAD_TIMEOUT=30
# DOWNLOAD_VIDEO_TIMEOUT=600
